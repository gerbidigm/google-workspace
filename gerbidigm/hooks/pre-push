#!/usr/bin/env bash
# Pre-push hook: enforce that upstream/main is always an ancestor of origin/main.
#
# Policy:
#   - Pushes to origin on any branch except main: always allowed.
#   - Pushes to origin/main: upstream/main must be an ancestor of the commits
#     being pushed (i.e. upstream has already been merged into main).
#   - Pushes to any other remote: allowed (no upstream check needed).

REMOTE="$1"

# Only enforce policy when pushing to origin.
if [ "$REMOTE" != "origin" ]; then
  exit 0
fi

# Read the refs being pushed from stdin.
# Format: <local ref> <local sha> <remote ref> <remote sha>
pushing_main=0
while read -r local_ref local_sha remote_ref _remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ] && [ "$local_sha" != "0000000000000000000000000000000000000000" ]; then
    pushing_main=1
    main_sha="$local_sha"
  fi
done

# Nothing targeting main — allow.
if [ "$pushing_main" -eq 0 ]; then
  exit 0
fi

# Fetch upstream quietly; if upstream isn't configured, skip the check.
if ! git remote get-url upstream &>/dev/null; then
  echo "ℹ  No 'upstream' remote configured; skipping upstream ancestry check."
  exit 0
fi

git fetch upstream --quiet 2>/dev/null

UPSTREAM_SHA=$(git rev-parse upstream/main 2>/dev/null)
if [ -z "$UPSTREAM_SHA" ]; then
  echo "ℹ  Could not resolve upstream/main; skipping upstream ancestry check."
  exit 0
fi

# Check that upstream/main is an ancestor of what we're pushing to main.
if ! git merge-base --is-ancestor "$UPSTREAM_SHA" "$main_sha" 2>/dev/null; then
  BEHIND=$(git rev-list --count "$main_sha"..upstream/main 2>/dev/null)
  echo ""
  echo "✘  Push to origin/main rejected."
  echo "   upstream/main is $BEHIND commit(s) ahead and is not an ancestor of your main."
  echo ""
  echo "   Sync first:"
  echo "     git fetch upstream"
  echo "     git rebase upstream/main   # or: git merge upstream/main"
  echo "     git push origin main"
  echo ""
  exit 1
fi
